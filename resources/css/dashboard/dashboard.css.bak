/**
 * Dashboard Styles - FitLife
 * Modern dark theme dashboard with gradient accents
 */

/* ================================
   Global SVG Reset for Dashboard
   ================================ */
.dashboard-page svg {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    fill: currentColor;
}

/* ================================
   Dashboard Layout
   ================================ */
.dashboard-page {
    padding: 0;
}

.dashboard-header {
    margin-bottom: 2rem;
    position: relative;
}

.dashboard-greeting {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.dashboard-greeting span {
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.dashboard-date {
    font-size: 0.9375rem;
    color: var(--text-muted);
}

/* ================================
   Stats Cards Row
   ================================ */
.stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
}

@media (max-width: 1200px) {
    .stats-row {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 640px) {
    .stats-row {
        grid-template-columns: 1fr;
    }
}

.stat-card {
    background: #111111;
    border: 1px solid #27272a;
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    transform: scaleX(0);
    transition: transform 0.3s ease;
}

.stat-card:hover {
    border-color: #22c55e;
    transform: translateY(-4px);
}

.stat-card:hover::before {
    transform: scaleX(1);
}

.stat-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
}

.stat-card-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    min-height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.stat-card-icon svg {
    width: 26px;
    height: 26px;
    min-width: 26px;
    min-height: 26px;
    max-width: 26px;
    max-height: 26px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
}

.stat-card-icon.calories {
    background: rgba(249, 115, 22, 0.15);
    color: #f97316;
}

.stat-card-icon.water {
    background: rgba(14, 165, 233, 0.15);
    color: #0ea5e9;
}

.stat-card-icon.sleep {
    background: rgba(168, 85, 247, 0.15);
    color: #a855f7;
}

.stat-card-icon.goals {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
}

.stat-card-trend {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
}

.stat-card-trend.up {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
}

.stat-card-trend.down {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
}

.stat-card-trend svg {
    width: 12px;
    height: 12px;
    fill: currentColor;
}

.stat-card-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 0.25rem;
}

.stat-card-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
}

.stat-card-progress {
    height: 6px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    overflow: hidden;
}

.stat-card-progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.5s ease;
}

.stat-card-progress-fill.calories { background: #f97316; }
.stat-card-progress-fill.water { background: #0ea5e9; }
.stat-card-progress-fill.sleep { background: #a855f7; }
.stat-card-progress-fill.goals { background: #22c55e; }

.stat-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
}

/* ================================
   Main Grid
   ================================ */
.dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 1.5rem;
}

@media (max-width: 1024px) {
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}

.dashboard-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.dashboard-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

/* ================================
   Cards
   ================================ */
.dash-card {
    background: #111111;
    border: 1px solid #27272a;
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
}

.dash-card:hover {
    border-color: rgba(34, 197, 94, 0.3);
}

.dash-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #27272a;
}

.dash-card-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
}

.dash-card-title svg {
    width: 20px;
    height: 20px;
    fill: #22c55e;
}

.dash-card-action {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #a1a1aa;
    text-decoration: none;
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    border: 1px solid #27272a;
    transition: all 0.3s ease;
}

.dash-card-action:hover {
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    color: #0a0a0a;
    border-color: transparent;
}

.dash-card-body {
    padding: 1.25rem 1.5rem;
}

/* ================================
   Events List
   ================================ */
.events-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.event-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: rgba(17, 17, 17, 0.5);
    border-radius: 12px;
    border-left: 3px solid transparent;
    border-image: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%) 1;
    transition: all 0.3s ease;
    border: 1px solid #27272a;
    border-left: 3px solid;
    border-left-color: #22c55e;
}

.event-item:hover {
    background: rgba(34, 197, 94, 0.05);
    border-color: rgba(34, 197, 94, 0.3);
    border-left-color: #22c55e;
}

.event-item.workout { border-left-color: #ef4444; }
.event-item.meal { border-left-color: #f97316; }
.event-item.sleep { border-left-color: #a855f7; }
.event-item.measurement { border-left-color: #22c55e; }

.event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 10px;
    flex-shrink: 0;
}

.event-date-day {
    font-size: 1.125rem;
    font-weight: 700;
    color: #fafafa;
    line-height: 1;
}

.event-date-month {
    font-size: 0.6875rem;
    color: #a1a1aa;
    text-transform: uppercase;
    margin-top: 2px;
}

.event-info {
    flex: 1;
    min-width: 0;
}

.event-type {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.25rem;
}

.event-desc {
    font-size: 0.875rem;
    color: #d4d4d8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.event-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(6, 182, 212, 0.15) 100%);
    color: #22c55e;
}

.event-badge.today {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(6, 182, 212, 0.15) 100%);
    color: #22c55e;
}

.event-badge.tomorrow {
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.15) 0%, rgba(245, 158, 11, 0.15) 100%);
    color: #f97316;
}

/* ================================
   Goals List
   ================================ */
.goals-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.goal-item {
    padding: 1rem;
    background: rgba(17, 17, 17, 0.5);
    border: 1px solid #27272a;
    border-radius: 12px;
    transition: all 0.3s ease;
}

.goal-item:hover {
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.05);
}

.goal-item-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
}

.goal-item-type {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fafafa;
}

.goal-item-percent {
    font-size: 0.875rem;
    font-weight: 600;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.goal-item-percent.complete {
    background: linear-gradient(135deg, #22c55e 0%, #10b981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.goal-item-progress {
    height: 6px;
    background: rgba(39, 39, 42, 0.8);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
}

.goal-item-progress-fill {
    height: 100%;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    border-radius: 3px;
    transition: width 0.5s ease;
}

.goal-item-progress-fill.complete {
    background: linear-gradient(135deg, #22c55e 0%, #10b981 100%);
}

.goal-item-progress-fill.warning {
    background: linear-gradient(135deg, #f97316 0%, #f59e0b 100%);
}

.goal-item-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #a1a1aa;
}

.goal-item-footer span {
    color: #d4d4d8;
}

/* ================================
   Photos Grid
   ================================ */
.photos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
}

@media (max-width: 768px) {
    .photos-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.photo-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid #27272a;
    transition: all 0.3s ease;
}

.photo-item:hover {
    border-color: rgba(34, 197, 94, 0.4);
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.15);
}

.photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.photo-item:hover img {
    transform: scale(1.05);
}

.photo-item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
}

.photo-item:hover .photo-item-overlay {
    opacity: 1;
}

.photo-item-date {
    font-size: 0.75rem;
    color: white;
    font-weight: 500;
}

/* ================================
   Profile Card
   ================================ */
.profile-card {
    text-align: center;
    background: #111111;
    border: 1px solid #27272a;
    border-radius: 16px;
    padding: 1.5rem;
}

.profile-card-avatar {
    width: 88px;
    height: 88px;
    border-radius: 20px;
    object-fit: cover;
    margin: 0 auto 1rem;
    border: 3px solid transparent;
    background: linear-gradient(#111111, #111111) padding-box,
                linear-gradient(135deg, #22c55e 0%, #06b6d4 100%) border-box;
}

.profile-card-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.profile-card-username {
    font-size: 0.875rem;
    color: #a1a1aa;
    margin-bottom: 1.5rem;
}

.profile-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
}

.profile-stat-item {
    padding: 1rem;
    background: #1a1a1a;
    border: 1px solid #27272a;
    border-radius: 12px;
    text-align: center;
    transition: all 0.3s ease;
}

.profile-stat-item:hover {
    border-color: rgba(34, 197, 94, 0.3);
}

.profile-stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.25rem;
}

.profile-stat-label {
    font-size: 0.75rem;
    color: #a1a1aa;
}

.profile-card-btn {
    display: block;
    width: 100%;
    padding: 0.875rem 1rem;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    border: none;
    border-radius: 10px;
    color: #0a0a0a;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
}

.profile-card-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(34, 197, 94, 0.4);
}

/* ================================
   Friends List
   ================================ */
.friends-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.friend-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid transparent;
}

.friend-item:hover {
    background: rgba(34, 197, 94, 0.05);
    border-color: rgba(34, 197, 94, 0.2);
}

.friend-avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid #27272a;
}

.friend-info {
    flex: 1;
    min-width: 0;
}

.friend-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fafafa;
    display: block;
}

.friend-username {
    font-size: 0.8125rem;
    color: #a1a1aa;
}

/* ================================
   Empty State
   ================================ */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem;
    text-align: center;
}

.empty-state-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
}

.empty-state-icon svg {
    width: 28px;
    height: 28px;
    fill: #22c55e;
}

.empty-state-text {
    font-size: 0.875rem;
    color: #a1a1aa;
    margin-bottom: 1rem;
}

.empty-state-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    color: white;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
}

.empty-state-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(34, 197, 94, 0.4);
}

/* ================================
   Lightbox
   ================================ */
.lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}

.lightbox.active {
    opacity: 1;
    visibility: visible;
}

.lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(20px);
}

.lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
}

.lightbox-content img {
    max-width: 100%;
    max-height: 85vh;
    border-radius: 16px;
    object-fit: contain;
    border: 1px solid #27272a;
}

.lightbox-close {
    position: absolute;
    top: -48px;
    right: 0;
    width: 40px;
    height: 40px;
    background: #111111;
    border: 1px solid #27272a;
    border-radius: 10px;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.lightbox-close:hover {
    background: #1a1a1a;
    border-color: #22c55e;
}

.lightbox-close svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
}

.lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: #111111;
    border: 1px solid #27272a;
    border-radius: 12px;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.lightbox-nav:hover {
    background: #1a1a1a;
    border-color: #22c55e;
}

.lightbox-nav.prev { left: -64px; }
.lightbox-nav.next { right: -64px; }

.lightbox-nav svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
}

.lightbox-info {
    margin-top: 1rem;
    text-align: center;
    color: #a1a1aa;
    font-size: 0.875rem;
}

@media (max-width: 768px) {
    .lightbox-nav.prev { left: 1rem; }
    .lightbox-nav.next { right: 1rem; }
}
